{
  "manifest_version": 3,
  "name": "Last Meadow Online Automation",
  "version": "1.3.0",
  "description": "Activity automation tool for Last Meadow Online on Discord. For educational purposes only.",
  "author": "dodoflix",
  "homepage_url": "https://github.com/dodoflix/last-meadow-online-automation",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/*",
        "https://ptb.discord.com/*",
        "https://canary.discord.com/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://discord.com/*",
        "https://ptb.discord.com/*",
        "https://canary.discord.com/*"
      ],
      "js": [
        "loader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "last-meadow-online@dodoflix",
      "strict_min_version": "128.0"
    }
  }
}
